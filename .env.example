# ==============================================================================
# .env.example — Copy to .env and fill in your real values.
# .env is gitignored — NEVER commit secrets to version control.
# ==============================================================================

# ── Alpha Vantage ──────────────────────────────────────────────────────────────
# Free tier: https://www.alphavantage.co/support/#api-key
# Free tier: 25 requests/day, 5 requests/minute.
# Premium: 75 requests/minute (recommended for production).
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# Seconds to sleep between ticker requests (rate-limit protection).
# Free tier: set to 15. Premium: set to 2.
API_SLEEP_SECONDS=15

# ── GCP ───────────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id

# Output from: terraform output gcs_bucket_name
GCS_BUCKET_NAME=your-gcp-project-id-market-data-lake

# ── BigQuery ──────────────────────────────────────────────────────────────────
BQ_DATASET=market_analytics

# ── Credentials ───────────────────────────────────────────────────────────────
# Path to the GCP service account JSON key.
# Terraform generates this at credentials/service_account.json.
GOOGLE_APPLICATION_CREDENTIALS=/opt/airflow/credentials/service_account.json

# ── Airflow ───────────────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=your_fernet_key_here

# UID of the user running Airflow (avoids volume permission issues on Linux)
# On Linux: run `id -u` to get your UID.
# On Mac: leave as 50000 (default Airflow UID).
AIRFLOW_UID=50000

# ── dbt ───────────────────────────────────────────────────────────────────────
# dbt reads GCP credentials from GOOGLE_APPLICATION_CREDENTIALS above.
# No additional variables needed.
